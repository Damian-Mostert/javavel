# Application
APP_NAME=Overreact
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
PORT=3000

# Authentication
AUTH_MODE=jwt
AUTH_SECRET=change-this-to-a-random-secret-key

# Database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=overreact
DB_USERNAME=root
DB_PASSWORD=

# Mail
MAIL_PROVIDER=smtp
MAIL_FROM_ADDRESS=noreply@overeact.dev
MAIL_FROM_NAME=overeact
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Sockets
SOCKETS_ENABLED=true
SOCKETS_PORT=3001
SOCKETS_CORS_ORIGIN=*

# Storage
STORAGE_DRIVER=local
