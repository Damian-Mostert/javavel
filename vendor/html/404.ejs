<!doctype html>
<html>
  <head>
    <title>404 Page not found</title>
    <script type="importmap">
      {
        "imports": {
          "react": "https://esm.sh/react@19.2.4<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react-dom": "https://esm.sh/react-dom@19.2.4<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react-dom/client": "https://esm.sh/react-dom@19.2.4/client<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react/jsx-runtime": "https://esm.sh/react@19.2.4/jsx-runtime<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "lucide-react": "https://esm.sh/lucide-react@0.468.0"
        }
      }
    </script>
  </head>
  <body>
    <script type="module">
      import React from "react";
      import { createRoot } from "react-dom/client";
      window.React = React;
      window.__EARLY_ERRORS__ = [];
      
      let root = null;
      
      function getRoot() {
        if (!root) {
          root = createRoot(document.body);
        }
        return root;
      }
      
      async function showErrorPage() {
        try {
          const errorModule = await import("/_overreact/app/Client/error.js");
          const ErrorComponent = errorModule.default;
          
          let DevConsole = null;
          const isDevMode = "<%= process.env.DEV_MODE %>" === "true";
          
          if (isDevMode) {
            try {
              const devConsoleModule = await import("/_overreact/vendor/client/components/DevConsole.js");
              DevConsole = devConsoleModule.default;
            } catch (e) {
              console.error("Failed to load DevConsole:", e);
            }
          }
          
          const App = () =>
            React.createElement(
              React.Fragment,
              null,
              React.createElement(ErrorComponent),
              DevConsole && React.createElement(DevConsole),
            );
          
          getRoot().render(React.createElement(App));
        } catch (e) {
          console.error("Error page failed to load:", e);
          document.body.innerHTML = `
            <div style="text-align:center;padding:50px;font-family:sans-serif;">
              <h1 style="color:#ef4444;">Critical Error</h1>
              <p>The application encountered a critical error and could not recover.</p>
            </div>
          `;
        }
      }
      
      window.addEventListener("error", (event) => {
        window.__EARLY_ERRORS__.push({
          type: "error",
          message: event.message,
          stack: event.error?.stack,
          timestamp: new Date(),
        });
        setTimeout(showErrorPage, 50);
      });
      
      window.addEventListener("unhandledrejection", (event) => {
        window.__EARLY_ERRORS__.push({
          type: "error",
          message: `Unhandled Promise Rejection: ${event.reason}`,
          timestamp: new Date(),
        });
        setTimeout(showErrorPage, 50);
      });
      
      async function render404() {
        try {
          const pageModule = await import("/_overreact/app/Client/not-found.js");
          const PageComponent = pageModule.default;
          
          const isDevMode = "<%= process.env.DEV_MODE %>" === "true";
          
          let DevConsole = null;
          if (isDevMode) {
            try {
              const devConsoleModule = await import("/_overreact/vendor/client/components/DevConsole.js");
              DevConsole = devConsoleModule.default;
            } catch (e) {
              console.error("Failed to load DevConsole:", e);
            }
          }
          
          const App = () => {
            const elements = [React.createElement(PageComponent)];
            if (DevConsole) {
              elements.push(React.createElement(DevConsole));
            }
            return React.createElement(React.Fragment, null, ...elements);
          };
          
          getRoot().render(React.createElement(App));
        } catch (error) {
          window.__EARLY_ERRORS__.push({
            type: "error",
            message: String(error),
            stack: error?.stack,
            timestamp: new Date(),
          });
          
          showErrorPage();
        }
      }
      
      render404();
    </script>
  </body>
</html>
