<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= page %></title>
    <script type="importmap">
      {
        "imports": {
          "react": "https://esm.sh/react@19.2.4<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react-dom": "https://esm.sh/react-dom@19.2.4<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react-dom/client": "https://esm.sh/react-dom@19.2.4/client<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "react/jsx-runtime": "https://esm.sh/react@19.2.4/jsx-runtime<% if (process.env.DEV_MODE === 'true') { %>?dev<% } %>",
          "lucide-react": "https://esm.sh/lucide-react@0.468.0"
        }
      }
    </script>
  </head>
  <body>
    <script type="module">
      window.__RENDER_CONFIG__ = {
        layout: <%- layout ? `"${layout}"` : 'null' %>,
        page: "<%- page %>",
        props: <%- JSON.stringify(props || {}) %>,
        devMode: <%= process.env.DEV_MODE === 'true' ? 'true' : 'false' %>
      };
    </script>
    <script
      type="module"
      src="/_overreact/vendor/client/components/bootstrap.js"
    ></script>
  </body>
</html>
